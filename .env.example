TCONNECT_EMAIL=your-email@example.com
TCONNECT_PASSWORD=your-password
# Defaults to US; set EU if your account is in Europe.
TCONNECT_REGION=US
TIMEZONE_NAME=America/New_York
# Optional if Tandem Source requires the pump identity in API requests
# PUMP_SERIAL_NUMBER=1234567890
# Optional overrides for local runtime and cloud output locations
# BAYESIAN_T1DM_RUNTIME_ROOT=/Users/you/ProjectsRuntime/bayesian-t1dm
# BAYESIAN_T1DM_CLOUD_ROOT=/Users/you/Library/CloudStorage/OneDrive-Personal/SideProjects/bayesian-t1dm
